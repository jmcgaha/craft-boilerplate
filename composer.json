{
	"name": "jmcgaha/craft-boilerplate",
	"description": "Craft CMS",
	"keywords": [
		"craft",
		"cms",
		"craftcms",
		"project"
	],
	"license": "0BSD",
	"homepage": "https://craftcms.com/",
	"type": "project",
	"support": {
		"email": "support@craftcms.com",
		"issues": "https://github.com/craftcms/cms/issues",
		"forum": "https://craftcms.stackexchange.com/",
		"source": "https://github.com/craftcms/cms",
		"docs": "https://craftcms.com/docs",
		"rss": "https://craftcms.com/changelog.rss"
	},
	"require": {
		"boccdotdev/polymedia": "^1.2.1",
		"craftcms/ckeditor": "^5.6.1",
		"craftcms/cms": "^5.10.5",
		"jainilnagar/env-beacon": "^1.0.0",
		"nystudio107/craft-templatecomments": "^5.0.6",
		"nystudio107/craft-vite": "^5.0.1",
		"vlucas/phpdotenv": "^5.6.3"
	},
	"require-dev": {
		"craftcms/generator": "^2.2.0",
		"craftcms/phpstan": "dev-main",
		"craftcms/rector": "dev-main",
		"yiisoft/yii2-shell": "^2.0.6"
	},
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true
		},
		"sort-packages": true,
		"optimize-autoloader": true,
		"platform": {
			"php": "8.4"
		}
	},
	"scripts": {
		"craft-update": [
			"@php craft install/check && php craft clear-caches/compiled-templates --interactive=0 && php craft clear-caches/compiled-classes --interactive=0 && php craft clear-caches/cp-resources --interactive=0 && php craft clear-caches/data --interactive=0 || exit 0",
			"@php craft install/check && php craft up --interactive=0 || exit 0"
		],
		"post-install-cmd": [
			"@craft-update"
		],
		"post-update-cmd": [
			"@craft-update"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
			"@php -r \"file_exists('scripts/.env.sh') || copy('scripts/example.env.sh', 'scripts/.env.sh');\""
		],
		"post-create-project-cmd": [
			"@php craft install"
		]
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
